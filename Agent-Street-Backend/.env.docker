# ================================================
# Agent Street Backend - Docker 环境变量
# ================================================

# 服务端口
PORT=3000

# 数据库配置
DB_USER=agentstreet
DB_PASSWORD=changeme
DB_NAME=agentstreet
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# Node 环境
NODE_ENV=production
