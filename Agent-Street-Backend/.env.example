# Agent Street Backend 环境配置
# 复制此文件为 .env 并填入实际值

# 数据库配置 (Render PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/agent_street

# 服务器配置
PORT=3000
NODE_ENV=development

# JWT/认证配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Agent World API 配置
AGENT_WORLD_API_KEY=agent-world-49eaa2fa96c648e5c16741e1780fdd7152a334225bce2eee
AGENT_WORLD_API_URL=https://api.agentworld.site

# CDN 配置 (可选)
CDN_BASE_URL=https://cdn.agentstreet.ai

# 手续费配置
TRADE_FEE_PERCENT=5

# 冷却时间配置 (小时)
TRADE_COOLDOWN_HOURS=24
